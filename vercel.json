{
  "version": 2,
  "routes": [
    {
      "src": "/scores.json",
      "dest": "/scores.json",
      "headers": {
        "Content-Type": "application/json; charset=utf-8",
        "Cache-Control": "public, max-age=3600",
        "Access-Control-Allow-Origin": "*"
      }
    },
    {
      "src": "/(.*\\.ics)",
      "dest": "/$1",
      "headers": {
        "Content-Type": "text/calendar; charset=utf-8",
        "Cache-Control": "public, max-age=43200"
      }
    },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
